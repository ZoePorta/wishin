{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ESNext", "DOM"],
    "types": ["vitest/globals"]
  },
  "include": [
    "src/**/*",
    "**/*.test.ts",
    "**/*.spec.ts",
    "vitest.config.ts",
    "test/integration/setup.ts"
  ]
}
