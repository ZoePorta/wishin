# --- APPWRITE INFRASTRUCTURE ---
EXPO_PUBLIC_APPWRITE_PROJECT_ID=
EXPO_PUBLIC_APPWRITE_PROJECT_NAME=Wishin
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1

# --- DATABASE & STORAGE ---
EXPO_PUBLIC_APPWRITE_DATABASE_ID=wishin
EXPO_PUBLIC_APPWRITE_STORAGE_BUCKET_ID=
# Change EXPO_PUBLIC_DB_PREFIX to 'test' when running integration tests locally
EXPO_PUBLIC_DB_PREFIX=dev

# --- DEVELOPMENT FLAGS ---
# WARNING: Only set to true for debugging specific permission issues in development.
DEV_ALLOW_OPEN_PERMISSIONS=false
EXPO_PUBLIC_BASE_URL=https://wishin.appwrite.network/

# --- SERVER SIDE ONLY ---
# (NEVER prefix with EXPO_PUBLIC_)
APPWRITE_API_SECRET=

